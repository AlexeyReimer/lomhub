{
  "name": "lomhub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx database/seed.ts",
    "db:generate": "prisma generate --schema=database/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=database/schema.prisma",
    "db:seed": "tsx database/seed.ts",
    "db:studio": "prisma studio --schema=database/schema.prisma",
    "predb:seed": "prisma generate --schema=database/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.10.1",
    "clsx": "^2.1.1",
    "next": "^15.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@next/eslint-plugin-next": "^15.5.19",
    "@tailwindcss/postcss": "^4.1.10",
    "@types/node": "^22.15.33",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@yandex/ymaps3-types": "^1.0.19996773",
    "eslint": "^9.29.0",
    "eslint-config-next": "^15.3.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "postcss": "^8.5.6",
    "prettier": "^3.5.3",
    "prisma": "^6.10.1",
    "tailwindcss": "^4.1.10",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "prisma": {
    "schema": "database/schema.prisma",
    "seed": "tsx database/seed.ts"
  }
}
