generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  YARD_OWNER
  ADMIN
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  phone        String    @unique
  passwordHash String
  fullName     String
  role         UserRole  @default(USER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  companies    Company[]
  reviews      Review[]

  @@index([role])
}

model Company {
  id          String      @id @default(uuid())
  ownerId     String
  name        String
  inn         String      @unique
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  owner       User        @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  yards       ScrapYard[]

  @@index([ownerId])
}

model City {
  id        String      @id @default(uuid())
  name      String
  slug      String      @unique
  region    String
  latitude  Decimal     @db.Decimal(10, 7)
  longitude Decimal     @db.Decimal(10, 7)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  yards     ScrapYard[]

  @@index([slug])
}

model ScrapYard {
  id           String       @id @default(uuid())
  companyId    String
  cityId       String
  name         String
  slug         String       @unique
  description  String?
  address      String
  latitude     Decimal?     @db.Decimal(10, 7)
  longitude    Decimal?     @db.Decimal(10, 7)
  phone        String?
  whatsapp     String?
  telegram     String?
  website      String?
  workingHours String?
  isVerified   Boolean      @default(false)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  city         City         @relation(fields: [cityId], references: [id], onDelete: Restrict)
  prices       YardPrice[]
  photos       YardPhoto[]
  reviews      Review[]

  @@index([slug])
  @@index([cityId])
  @@index([companyId])
}

model ScrapCategory {
  id        String       @id @default(uuid())
  name      String
  slug      String       @unique
  sortOrder Int          @default(0)
  isActive  Boolean      @default(true)
  groups    ScrapGroup[]
}

model ScrapGroup {
  id         String        @id @default(uuid())
  categoryId String
  name       String
  slug       String        @unique
  sortOrder  Int           @default(0)
  isActive   Boolean       @default(true)
  category   ScrapCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  types      ScrapType[]

  @@index([categoryId])
}

model ScrapType {
  id          String      @id @default(uuid())
  groupId     String
  code        String      @unique
  name        String
  slug        String      @unique
  description String?
  unit        String      @default("кг")
  sortOrder   Int         @default(0)
  isActive    Boolean     @default(true)
  group       ScrapGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  prices      YardPrice[]

  @@index([groupId])
}

model YardPrice {
  id                   String         @id @default(uuid())
  yardId               String
  scrapTypeId          String
  price                Decimal        @db.Decimal(12, 2)
  contaminationPercent Decimal        @default(0) @db.Decimal(5, 2)
  isAccepting          Boolean        @default(true)
  comment              String?
  updatedAt            DateTime       @updatedAt
  yard                 ScrapYard      @relation(fields: [yardId], references: [id], onDelete: Cascade)
  scrapType            ScrapType      @relation(fields: [scrapTypeId], references: [id], onDelete: Restrict)
  history              PriceHistory[]

  @@unique([yardId, scrapTypeId])
  @@index([yardId])
  @@index([scrapTypeId])
}

model PriceHistory {
  id                         String    @id @default(uuid())
  yardPriceId                String
  oldPrice                   Decimal?  @db.Decimal(12, 2)
  newPrice                   Decimal   @db.Decimal(12, 2)
  oldContaminationPercent    Decimal?  @db.Decimal(5, 2)
  newContaminationPercent    Decimal   @db.Decimal(5, 2)
  createdAt                  DateTime  @default(now())
  yardPrice                  YardPrice @relation(fields: [yardPriceId], references: [id], onDelete: Cascade)

  @@index([yardPriceId])
}

model YardPhoto {
  id        String    @id @default(uuid())
  yardId    String
  imageUrl  String
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  yard      ScrapYard @relation(fields: [yardId], references: [id], onDelete: Cascade)

  @@index([yardId])
}

model Review {
  id          String    @id @default(uuid())
  yardId      String
  userId      String
  rating      Int
  text        String
  answer      String?
  isPublished Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  yard        ScrapYard @relation(fields: [yardId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([yardId])
  @@index([userId])
}
